datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

model University {
  id        String   @id @default(uuid())
  name      String
  ukprn     String?  @unique
  address   Json?
  website   String?
  logoUrl   String?
  
  courses   Course[]
}

model Course {
  id              String   @id @default(uuid())
  ucasCourseId    String   @unique
  title           String
  applicationCode String?
  summary         String?
  courseUrl       String?
  
  universityId    String
  university      University @relation(fields: [universityId], references: [id])
  
  options         CourseOption[]
}

model CourseOption {
  id              String   @default(uuid())
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id])
  
  year            Int
  studyMode       String   @default("Full-time")
  duration        String   @default("3 Years")
  startDate       String?
  
  homeFee         Float?
  internationalFee Float?
  
  // A-Level Requirements
  aLevelGrade1    String?
  aLevelSubject1  String?
  aLevelGrade2    String?
  aLevelSubject2  String?
  aLevelGrade3    String?
  aLevelSubject3  String?
  aLevelGrade4    String?
  aLevelSubject4  String?
  
  // English Language Requirements
  englishSpeaking  String?
  englishListening String?
  englishReading   String?
  englishWriting   String?
  englishOverall   String?

  outcomeQualification String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@id([courseId, year, studyMode, duration])
}

enum ScrapeStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}

model Scrape {
  id         String        @id @default(uuid())
  startedAt  DateTime
  finishedAt DateTime?
  status     ScrapeStatus  @default(PENDING)
  type       String?
  issues     ScrapeIssue[]
  createdAt  DateTime      @default(now())
}

model ScrapeIssue {
  id           String   @id @default(uuid())
  scrapeId     String
  scrape       Scrape   @relation(fields: [scrapeId], references: [id])
  courseId     String?
  universityId String?
  message      String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}