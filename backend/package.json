{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development ts-node src/index.ts",
    "dev:client": "npm run dev --prefix ../frontend",
    "build:server": "tsc",
    "build:client": "npm run build --prefix ../frontend",
    "build": "npm run build:server && npm run build:client",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "cross-env NODE_ENV=development ts-node src/scripts/test.ts",
    "demo": "ts-node src/demo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@quixo3/prisma-session-store": "^3.1.19",
    "@types/node": "^24.10.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "pdf-parse": "^2.4.5",
    "prisma": "^5.22.0",
    "puppeteer": "^24.36.0",
    "string-similarity": "^4.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/string-similarity": "^4.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  }
}
